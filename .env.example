# Copy to .env and fill in. NEVER commit your real .env.
# Generate a token with:  python3 -c "import secrets;print(secrets.token_urlsafe(32))"

MCP_BRIDGE_TOKEN=replace-with-a-long-random-token

# Bind address. Keep 127.0.0.1 and reach it via SSH tunnel or a private VPN.
MCP_BRIDGE_HOST=127.0.0.1
MCP_BRIDGE_PORT=8765
MCP_BRIDGE_PATH=/mcp

# Shell used by run_command.
MCP_BRIDGE_SHELL=/bin/zsh

# Optional defense-in-depth: only allow these IPs / CIDRs (comma separated).
# MCP_BRIDGE_ALLOW_IPS=127.0.0.1,::1,100.64.0.0/10,192.168.1.0/24

# Optional filesystem jail: confine all file/binary ops under this directory.
# MCP_BRIDGE_ROOT=/Users/me/mcp-sandbox

# Optional TLS - serve HTTPS directly (no reverse proxy). Easiest trusted
# cert: `tailscale cert <machine>.<tailnet>.ts.net`. Or self-signed via
# examples/gen_self_signed_cert.sh.
# MCP_BRIDGE_TLS_CERT=/path/to/server.crt
# MCP_BRIDGE_TLS_KEY=/path/to/server.key
# MCP_BRIDGE_TLS_KEY_PASSWORD=


# Only enable behind a reverse proxy you control (X-Forwarded-For is spoofable).
# MCP_BRIDGE_TRUST_FORWARDED=0
